#!/usr/bin/expect -f

set timeout 5
set project_root [lindex $argv 0]

spawn /bin/bash "$project_root/tests/timeout_tty_read_fixture.sh" "$project_root" timeout

expect {
    -re {TIMEOUT:124\r?\n} {}
    timeout { exit 124 }
    eof { exit 1 }
}

expect {
    -re {READY-AFTER\r?\n} {}
    timeout { exit 124 }
    eof { exit 1 }
}

send -- "typed-after\r"

expect {
    -re {READ-AFTER:typed-after\r?\n} {}
    timeout { exit 124 }
    eof { exit 1 }
}

expect eof
set result [wait]
exit [lindex $result 3]
